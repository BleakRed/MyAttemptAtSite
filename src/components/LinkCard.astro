---
interface Props {
	title: string;
	url: string;
	description: string;
	category: string;
	icon?: string;
	iconPath?: string;
	featured?: boolean;
}
const { title, url, description, category, icon = '🔗', iconPath, featured = false } = Astro.props;
---

<style>
	.card {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		padding: 1rem 1.25rem;
		background: var(--color-card);
		border: 1px solid var(--color-border);
		border-radius: 10px;
		transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
		text-decoration: none;
		color: inherit;
	}

	.card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
		text-decoration: none;
	}

	.card.featured {
		border-color: var(--color-accent);
		background: var(--color-accent-bg);
	}

	.icon {
		font-size: 1.5rem;
		line-height: 1;
		flex-shrink: 0;
		margin-top: 1rem;
		width: 1.5rem;
		height: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.icon img,
	.icon svg {
		width: 100%;
		height: 100%;
    object-fit: contain;
	}

	.content {
		flex: 1;
		min-width: 0;
	}

	.title-row {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 0.25rem;
	}

	.title {
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.category {
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.1rem 0.4rem;
		border-radius: 4px;
		background: var(--color-accent-bg);
		color: var(--color-accent);
	}

	.description {
		font-size: 0.85rem;
		color: var(--color-muted);
		line-height: 1.5;
		margin: 0;
	}

	@media (max-width: 480px) {
		.card {
			padding: 0.875rem 1rem;
		}
		.icon {
			font-size: 1.25rem;
			width: 1.25rem;
			height: 1.25rem;
		}
	}
</style>

<a href={url} class={`card ${featured ? 'featured' : ''}`} target="_blank" rel="noopener noreferrer">
	<span class="icon" aria-hidden="true">
		{iconPath ? <img src={import.meta.env.BASE_URL.replace(/\/$/, '') + iconPath} alt="" /> : icon}
	</span>
	<div class="content">
		<div class="title-row">
			<h3 class="title">{title}</h3>
			<span class="category">{category}</span>
		</div>
		<p class="description">{description}</p>
	</div>
</a>
